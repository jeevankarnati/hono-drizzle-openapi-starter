{
  "name": "hono-drizzle-openapi",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "db:gen-fresh": "rm -rf src/db/migrations && bun db:generate",
    "db:generate": "drizzle-kit generate --name=hono-drizzle-openapi",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "husky",
    "quality": "npm run lint && npm run format",
    "quality:fix": "npm run lint:fix && npm run format:fix",
    "start": "node dist/index.js",
    "update-http-statuses": "bun scripts/update-http-statuses.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.10.6",
    "better-auth": "^1.6.0",
    "consola": "^3.4.2",
    "dotenv": "^17.4.1",
    "dotenv-expand": "^12.0.3",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.10",
    "hono-pino": "^0.10.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-check-file": "^3.3.1",
    "husky": "^9.1.7",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
